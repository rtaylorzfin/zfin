#!/usr/bin/env bash
set -euo pipefail

SCRIPT=$(basename "$0")

# zhelp / zstatus: informational only (no container work). Handle them before arg
# parsing and compose-file resolution, so they work even when nothing is activated.
case "$SCRIPT" in
  zhelp)
    cat <<'H'
z-commands (available inside an activated .zenv -- `source .zenv/activate`):
  zrun [svc] [args]    run a command in a fresh container (default svc: compile)
                       e.g. zrun -c "gradle dirtydeploy"
  zexec [svc] [args]   exec into the running container (default: compile)
  zup [svc...]         start service(s)
  zdown [svc...]       stop service(s)
  zpull [svc...]       pull image(s)
  zlog [svc...]        tail logs
  zrestart [svc]       restart a running container
  zfeature <cmd>       feature ops -- `zfeature new [<ticket>]`, `zfeature build-preloaded`
  zbuild <phase>       hands-free build/deploy -- configure|load-db|load-solr|deploy-jenkins|deploy|all
  zstatus              show the active stack: name, dir, url, containers
  zhelp                this help
  deactivate           leave the active .zenv (restores your shell)
H
    if [[ -n "${ZENV_ACTIVE:-}" ]]; then echo "active: ${ZENV_ACTIVE}"; else echo "active: (none) -- source <repo-or-worktree>/.zenv/activate"; fi
    exit 0
    ;;
  zstatus)
    if [[ -z "${ZENV_ACTIVE:-}" ]]; then
      echo "zenv: no feature active. Activate one:  source <repo-or-worktree>/.zenv/activate"
      exit 0
    fi
    ip=$(grep -E '^LOOPBACK_IP='   "${COMPOSE_ENV_FILES:-/dev/null}" 2>/dev/null | tail -1 | cut -d= -f2-) || true
    dbimg=$(grep -E '^ZFIN_DB_IMAGE=' "${COMPOSE_ENV_FILES:-/dev/null}" 2>/dev/null | tail -1 | cut -d= -f2-) || true
    echo "zenv: ${ZENV_ACTIVE}"
    [[ -n "${ZENV_DIR:-}"  ]] && echo "  dir      : ${ZENV_DIR}"
    [[ -n "${ZENV_HOST:-}" ]] && echo "  url      : https://${ZENV_HOST}${ip:+  ($ip)}"
    [[ -n "$dbimg" ]]         && echo "  images   : ${dbimg} (+ solr)"
    [[ -n "${PRELOADED_TAG:-}" ]] && echo "  tag      : ${PRELOADED_TAG}"
    echo "  compose  : ${COMPOSE_FILE:-<none>}"
    echo "  env-file : ${COMPOSE_ENV_FILES:-<none>}"
    echo
    echo "containers:"
    docker compose ps 2>/dev/null || echo "  (docker compose ps failed)"
    exit 0
    ;;
esac

usage() {
  case "$SCRIPT" in
    zrun)
      echo "Usage: zrun [service] [bash_args...]"
      echo "  service     Compose service to run (default: compile)"
      echo "  bash_args   Extra arguments passed to bash (e.g. -c 'ls -la')"
      echo "  Targets the active .zenv stack (source .zenv/activate first)."
      ;;
    zexec)
      echo "Usage: zexec [service] [bash_args...]"
      echo "  service     Compose service whose running container to exec into (default: compile)"
      echo "  bash_args   Extra arguments passed to bash (e.g. -c 'ls -la')"
      echo "  Resolves the container via 'docker compose exec' in the active .zenv stack."
      ;;
    zrestart)
      echo "Usage: zrestart [service]"
      echo "  service     Compose service to restart in the active .zenv stack"
      ;;
    zup)
      echo "Usage: zup [service...]"
      echo "  service     One or more services to start (default: all)"
      echo "  Acts on the active .zenv stack (source .zenv/activate first)."
      ;;
    zdown)
      echo "Usage: zdown [service...]"
      echo "  service     One or more services to stop (default: all)"
      echo "  Acts on the active .zenv stack (source .zenv/activate first)."
      ;;
    zpull)
      echo "Usage: zpull [service...]"
      echo "  service     One or more services to pull (default: all)"
      echo "  Acts on the active .zenv stack (source .zenv/activate first)."
      ;;
    zlog)
      echo "Usage: zlog [service...]"
      echo "  service     One or more services to tail logs for (default: all)"
      echo "  Acts on the active .zenv stack (source .zenv/activate first)."
      ;;
    *)
      echo "Must be invoked as 'zrun', 'zexec', 'zrestart', 'zup', 'zdown', 'zlog', or 'zpull'" >&2
      ;;
  esac
  exit 1
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && usage

# If first arg looks like a flag, treat it as a bash arg, not a service name
if [[ "${1:-}" == -* ]]; then
  SERVICE="compile"
else
  SERVICE="${1:-compile}"
  [[ $# -gt 0 ]] && shift
fi

# Extract docker flags (e.g. -u root) so they reach docker, not bash.
# Without this, `-u` would land at `bash -l -u ...` and enable nounset.
DOCKER_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -u|--user)
      [[ $# -lt 2 ]] && { echo "Error: $1 requires an argument" >&2; exit 1; }
      DOCKER_ARGS+=("$1" "$2")
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

# An active .zenv (or zbuild / GoCD) exports COMPOSE_PROJECT_NAME/COMPOSE_FILE, which
# `docker compose` reads natively -- so we pass no -f and act on exactly that stack.
# If nothing set it, there's no stack to target: tell the user to activate one.
if [[ -z "${COMPOSE_FILE:-}" ]]; then
  echo "Error: no COMPOSE_FILE in the environment -- activate a stack first:" >&2
  echo "  source <repo-or-worktree>/.zenv/activate" >&2
  exit 1
fi

case "$SCRIPT" in
  zrun)
    exec docker compose run --rm "${DOCKER_ARGS[@]}" "$SERVICE" bash -l "$@"
    ;;
  zrestart)
    # Compose resolves the service in the active project (COMPOSE_PROJECT_NAME/FILE from
    # the .zenv) -- no name-prefix guessing needed.
    exec docker compose restart "$SERVICE" "$@"
    ;;
  zexec)
    # Exec into THIS stack's running service via compose (exact, via the .zenv env).
    # compose exec allocates a TTY by default; disable it when stdin isn't a terminal.
    TTY_FLAG=(); [[ -t 0 ]] || TTY_FLAG=(-T)
    exec docker compose exec "${TTY_FLAG[@]}" "${DOCKER_ARGS[@]}" "$SERVICE" bash -l "$@"
    ;;
  zup)
    exec docker compose up -d "$SERVICE" "$@"
    ;;
  zdown)
    exec docker compose stop "$SERVICE" "$@"
    ;;
  zpull)
    exec docker compose pull "$SERVICE" "$@"
    ;;
  zlog)
    exec docker compose logs -f "$SERVICE" "$@"
    ;;
  *)
    echo "Error: must be invoked as 'zrun', 'zexec', 'zrestart', 'zup', 'zdown', or 'zpull'" >&2
    exit 1
    ;;
esac
